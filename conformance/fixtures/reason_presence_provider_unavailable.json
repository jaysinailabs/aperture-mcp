  "input": {
    "metric": "bridges",
    "graph": {
      "edges": [
        { "src": "a", "dst": "b", "label": "depends_on" },
        { "src": "b", "dst": "c", "label": "depends_on" }
      ]
    }
  },
  "expected": {
    "status": "provider_unavailable",
    "reason_required": true,
    "topology": {
      "cut_vertices": [],
